    "js-yaml": "^4.1.0",
    "next": "^15.5.12",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
