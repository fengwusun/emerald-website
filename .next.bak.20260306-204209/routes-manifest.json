{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/portal/targets/[emerald_id]",
      "regex": "^/portal/targets/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPemerald_id": "nxtPemerald_id"
      },
      "namedRegex": "^/portal/targets/(?<nxtPemerald_id>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/contact-data-policy",
      "regex": "^/contact\\-data\\-policy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/contact\\-data\\-policy(?:/)?$"
    },
    {
      "page": "/observing-plan",
      "regex": "^/observing\\-plan(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/observing\\-plan(?:/)?$"
    },
    {
      "page": "/portal",
      "regex": "^/portal(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal(?:/)?$"
    },
    {
      "page": "/portal/downloads",
      "regex": "^/portal/downloads(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/downloads(?:/)?$"
    },
    {
      "page": "/portal/login",
      "regex": "^/portal/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/login(?:/)?$"
    },
    {
      "page": "/portal/targets",
      "regex": "^/portal/targets(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/targets(?:/)?$"
    },
    {
      "page": "/science-goals",
      "regex": "^/science\\-goals(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/science\\-goals(?:/)?$"
    },
    {
      "page": "/science-projects",
      "regex": "^/science\\-projects(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/science\\-projects(?:/)?$"
    },
    {
      "page": "/team",
      "regex": "^/team(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/team(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}