6:["$","ul",null,{"children":[["$","li",null,{"children":"How do carbon abundance and electron-density distributions evolve with redshift, and what do they imply for bursty star formation and early chemical enrichment?"}],["$","li",null,{"children":"How do UV diagnostics (for example CIV, HeII, CIII], OIII], LyA) constrain ionization conditions, massive stellar populations, and AGN signatures at z~5-9?"}],["$","li",null,{"children":"How do DIVER UV constraints connect to EMERALD rest-optical diagnostics in the same systems?"}]]}]
7:["$","section",null,{"className":"card","children":[["$","h2",null,{"children":"Key Measurements and Diagnostics"}],["$","div",null,{"style":{"height":"1.5rem"}}],["$","h3",null,{"children":"EMERALD"}],["$","ul",null,{"children":[["$","li",null,{"children":"Rest-optical emission-line diagnostics to separate AGN-driven and star-formation-driven ionization."}],["$","li",null,{"children":"Broad-line AGN identification from deep spectroscopy in wavelength regions where previous wide-field slitless data are less complete."}],["$","li",null,{"children":"Joint interpretation with ancillary imaging and SED information to connect nuclear activity with host-galaxy context."}]]}],["$","h3",null,{"children":"DIVER"}],["$","ul",null,{"children":[["$","li",null,{"children":"Deep UV line measurements (including CIV, HeII, CIII], OIII]) for ionization, abundance, and density constraints."}],["$","li",null,{"children":"LyA constraints on reionization-era gas conditions and IGM transmission."}],["$","li",null,{"children":"Targeted UV spectroscopy of known AGNs, UV emitters from literature or the JADES NIRSpec database, bright high-z sources, and high-EW OIII/Halpha emitters from grism surveys."}]]}]]}]
