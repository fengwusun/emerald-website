tion",null,{"className":"card","children":[["$","h2",null,{"children":"Key Science Questions"}],["$","div",null,{"style":{"height":"1.5rem"}}],["$","h3",null,{"children":"EMERALD"}],["$","ul",null,{"children":[["$","li",null,{"children":"How does AGN incidence vary with galaxy properties, star-formation intensity, and evolutionary stage?"}],["$","li",null,{"children":"How does the AGN population evolve across redshift within the reionization-era and post-reionization universe?"}],["$","li",null,{"children":"What fraction of AGN activity is identifiable through broad-line versus narrow-line and high-ionization signatures?"}],["$","li",null,{"children":"How do selection effects and host-galaxy demographics influence inferred AGN fractions in high-redshift samples?"}]]}],"$L5","$L6"]}],"$L7","$L8"]}],null,"$L9"]}],{},null,false]},null,false]},null,false]},null,false],"$La",false]],"m":"$undefined","G":["$b",[]],"s":false,"S":true}
