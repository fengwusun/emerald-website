# Shared portal password (required for /portal access)
EMERALD_PORTAL_PASSWORD=change-me

# Cookie signing/verification secret (required)
EMERALD_PORTAL_COOKIE_SECRET=replace-with-long-random-secret

# Signed URL expiration in seconds
EMERALD_SIGNED_URL_TTL_SECONDS=900

# Optional object storage settings (S3-compatible)
AWS_REGION=us-east-1
EMERALD_ASSET_BUCKET=emerald-assets
EMERALD_ASSET_PREFIX=emerald/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=

# Local media directory used by /api/targets/image for source previews.
EMERALD_LOCAL_MEDIA_DIR=/Users/sunfengwu/Downloads/emerald_msa_ptg-2026
