# Shared portal/science-projects password (required).
EMERALD_PORTAL_PASSWORD=change-me

# Generic admin password for science-project admin mode.
EMERALD_ADMIN_PASSWORD=westlakebiggestsun

# Cookie signing/verification secret (required).
# Set a long random value.
EMERALD_PORTAL_COOKIE_SECRET=replace-with-long-random-secret

# Optional override only for science-projects admin mode.
# If unset, admin mode uses EMERALD_PORTAL_PASSWORD and EMERALD_PORTAL_COOKIE_SECRET.
EMERALD_SCIENCE_ADMIN_PASSWORD=
EMERALD_SCIENCE_ADMIN_COOKIE_SECRET=

# Optional Google Sheets-backed persistence for science projects.
# If these are set, science-project state is stored in Google Sheets instead of local JSON.
# Share the spreadsheet with the service-account email and ensure the target tabs/ranges exist.
SCIENCE_PROJECTS_GOOGLE_SHEETS_ID=
SCIENCE_PROJECTS_GOOGLE_PROJECTS_RANGE=Projects!A:I
SCIENCE_PROJECTS_GOOGLE_CONTENT_RANGE=Content!A:B
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Signed URL expiration in seconds
EMERALD_SIGNED_URL_TTL_SECONDS=900

# Optional object storage settings (S3-compatible)
AWS_REGION=us-east-1
EMERALD_ASSET_BUCKET=emerald-assets
EMERALD_ASSET_PREFIX=emerald/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=

# Local media directory used by /api/targets/image for source previews.
EMERALD_LOCAL_MEDIA_DIR=/Users/sunfengwu/Downloads/emerald_msa_ptg-2026

# Optional base path when serving behind a subpath (e.g. /emerald).
# Leave empty for local development.
NEXT_PUBLIC_BASE_PATH=
